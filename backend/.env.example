# ──────────────────────────────────────────────────────
# MCQ Generator — Backend Environment Variables
# Copy this file to `.env` and fill in the values.
# ──────────────────────────────────────────────────────

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:3000

# SMTP Mail Forwarding Configuration (Optional, falls back to Mock Mode if empty)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SUPPORT_EMAIL=support@verityiq.edu

# Resend API Configuration (Alternative to SMTP, recommended for Render Free tier)
# Get your free key at: https://resend.com
RESEND_API_KEY=
# Optional: Verified sender email domain. Default is "Verity IQ Support <onboarding@resend.dev>"
RESEND_FROM_EMAIL=

